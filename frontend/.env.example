# Copy this to .env and fill in your values
# On Vercel: add these in Project Settings > Environment Variables

VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_EXCHANGERATE_BASE=INR

# Optional — for real weather (https://openweathermap.org/api)
VITE_OPENWEATHER_KEY=your_openweather_key_here

# Optional — for real flights (https://developers.amadeus.com)
VITE_AMADEUS_API_KEY=your_amadeus_client_id_here
VITE_AMADEUS_API_SECRET=your_amadeus_client_secret_here

# Optional — for real hotels/trains (https://rapidapi.com)
VITE_RAPIDAPI_KEY=your_rapidapi_key_here

# Backend URL (set to your Render.com URL after backend deploy)
VITE_API_URL=https://your-backend.onrender.com/api
